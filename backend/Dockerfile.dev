FROM golang:alpine

# Set Go toolchain to auto (allows using newer Go versions)
ENV GOTOOLCHAIN=auto

# Install Air for hot-reload and additional tools
RUN apk add --no-cache git && \
    go install github.com/air-verse/air@latest

WORKDIR /app

# Copy go mod files
COPY go.mod go.sum ./

# Download dependencies
RUN go mod download

# Expose port
EXPOSE 8080

# Run Air
CMD ["air", "-c", ".air.toml"]
